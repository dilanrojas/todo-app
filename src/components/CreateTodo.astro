---
import Checkbox from "./Checkbox.astro"
---

<div class="create-todo">
  <Checkbox />
  <input
    type="text"
    class="input-todo-name"
    name="input-todo-name"
    id="input-todo-name"
    autocomplete="off"
    maxlength="40"
    placeholder="Create a new todo..."
  >
</div>

<style>
  .create-todo {
    margin-bottom: 1em;
    background-color: var(--primary-bg);
    box-shadow: var(--box-shadow);
    border-radius: 5px;
    transition: var(--theme-transition);

    display: flex;
    align-items: center;
    padding: var(--app-padding);

    input {
      border: 0;
      padding-top: .16em;
      color: var(--text);
      width: 100%;
    }

    input::placeholder {
      color: var(--text-secondary)
    }

    input:focus {
      outline: 0;
    }
  }
</style>